   RowBox[{"ew", "\[Rule]", "0.1`"}], ",", 
   RowBox[{"ep", "\[Rule]", "1"}], ",", 
   RowBox[{"v", "\[Rule]", "0.5`"}], ",", 
   RowBox[{"a", "\[Rule]", "0.005`"}], ",", 
   RowBox[{"e", "\[Rule]", "10"}]}], "}"}]], "Output",
 CellChangeTimes->{3.97681465567006*^9, 3.976814753329462*^9, 
  3.976814863696693*^9},
 CellLabel->
  "Out[137]=",ExpressionUUID->"dc96a828-b260-451e-bc4e-3a1542efc048"]
}, Open  ]],

