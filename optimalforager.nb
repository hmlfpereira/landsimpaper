Notebook[{
Cell["Based on Optimal_Forager.wxm from Theoretical Ecology class", "Text",
 CellChangeTimes->{{3.976814285512903*^9, 
  3.976814332457806*^9}},ExpressionUUID->"10f2ab57-8324-4ef3-8fab-\
67b2a9f8104d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"tw", ":=", 
   RowBox[{"1", "/", 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{"a", "*", "2", "\[Pi]", "*", "r"}], ",", 
      RowBox[{"{", 
       RowBox[{"r", ",", "0", ",", "rc"}], "}"}]}], "]"}]}]}], ";"}]], "Input",\

 CellChangeTimes->{{3.976813462706451*^9, 3.976813463154768*^9}, 
   3.976814846755837*^9},
 CellLabel->
  "In[129]:=",ExpressionUUID->"8414404e-f836-412c-8223-259f2a8a4c95"],

Cell[CellGroupData[{

Cell[BoxData["tw"], "Input",
 CellChangeTimes->{{3.976813454899394*^9, 3.976813456471991*^9}},
 CellLabel->
  "In[130]:=",ExpressionUUID->"98d4ab8f-4430-4028-a6cb-bf4780387ec5"],

Cell[BoxData[
 FractionBox["1", 
  RowBox[{"a", " ", "\[Pi]", " ", 
   SuperscriptBox["rc", "2"]}]]], "Output",
 CellChangeTimes->{{3.976813457372067*^9, 3.976813469344839*^9}, 
   3.976814566195958*^9, 3.976814863607806*^9},
 CellLabel->
  "Out[130]=",ExpressionUUID->"cf6f85da-a26a-41ca-b5cd-e4c5905c577b"]
}, Open  ]],

Cell[BoxData[
 RowBox[{"\n", 
  RowBox[{
   RowBox[{"tp", ":=", 
    RowBox[{
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{"2", "*", 
        RowBox[{"r", "/", "v"}], "*", "a", "*", "2", "\[Pi]", "*", "r"}], ",", 
       RowBox[{"{", 
        RowBox[{"r", ",", "0", ",", "rc"}], "}"}]}], "]"}], "/", 
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{"a", "*", "2", "\[Pi]", "*", "r"}], ",", 
       RowBox[{"{", 
        RowBox[{"r", ",", "0", ",", "rc"}], "}"}]}], "]"}]}]}], 
   ";"}]}]], "Input",
 CellChangeTimes->{{3.976814370618968*^9, 3.976814405750679*^9}, {
  3.97681485551947*^9, 3.976814857408805*^9}},
 CellLabel->
  "In[131]:=",ExpressionUUID->"2aead3b8-d022-4cf5-912b-e1bc6b783304"],

Cell[CellGroupData[{

Cell[BoxData["tp"], "Input",
 CellChangeTimes->{{3.976814396852908*^9, 3.97681439694249*^9}},
 CellLabel->
  "In[132]:=",ExpressionUUID->"43cb59fa-b1f6-44d6-aea5-a2e93e174267"],

Cell[BoxData[
 FractionBox[
  RowBox[{"4", " ", "rc"}], 
  RowBox[{"3", " ", "v"}]]], "Output",
 CellChangeTimes->{{3.976814397615589*^9, 3.9768144096544657`*^9}, 
   3.976814566218875*^9, 3.976814863638423*^9},
 CellLabel->
  "Out[132]=",ExpressionUUID->"3f1bde7b-1dea-4b6d-b02d-6329bdf9f9f6"]
}, Open  ]],

Cell[BoxData[
 RowBox[{"ti", ":=", 
  RowBox[{"tw", "+", "tp"}]}]], "Input",
 CellChangeTimes->{{3.9768144928837433`*^9, 3.976814500206903*^9}},
 CellLabel->
  "In[133]:=",ExpressionUUID->"a8a9646e-2c6d-4a92-8586-e6ef3559e763"],

Cell[BoxData[
 RowBox[{"ei", ":=", 
  RowBox[{"e", "-", 
   RowBox[{"ew", "*", "tw"}], "-", 
   RowBox[{"ep", "*", "tp"}]}]}]], "Input",
 CellChangeTimes->{{3.976814510265912*^9, 3.9768145187481823`*^9}},
 CellLabel->
  "In[134]:=",ExpressionUUID->"fce36b77-fffb-4c43-b51c-9fada5525671"],

Cell[BoxData[
 RowBox[{"et", ":=", 
  RowBox[{"ei", "/", "ti"}]}]], "Input",
 CellChangeTimes->{3.9768145353072977`*^9},
 CellLabel->
  "In[135]:=",ExpressionUUID->"23de0a3e-f726-47e1-82ae-98e3a4823414"],

Cell[CellGroupData[{

Cell[BoxData["et"], "Input",
 CellChangeTimes->{{3.976814541204361*^9, 3.9768145414384403`*^9}},
 CellLabel->
  "In[150]:=",ExpressionUUID->"cd54d926-a5be-4d7b-8948-59af6de59f3f"],

Cell[BoxData[
 FractionBox[
  RowBox[{"e", "-", 
   FractionBox["ew", 
    RowBox[{"a", " ", "\[Pi]", " ", 
     SuperscriptBox["rc", "2"]}]], "-", 
   FractionBox[
    RowBox[{"4", " ", "ep", " ", "rc"}], 
    RowBox[{"3", " ", "v"}]]}], 
  RowBox[{
   FractionBox["1", 
    RowBox[{"a", " ", "\[Pi]", " ", 
     SuperscriptBox["rc", "2"]}]], "+", 
   FractionBox[
    RowBox[{"4", " ", "rc"}], 
    RowBox[{"3", " ", "v"}]]}]]], "Output",
 CellChangeTimes->{{3.976814541865041*^9, 3.976814566248464*^9}, 
   3.976814863673439*^9, 3.976980096604232*^9},
 CellLabel->
  "Out[150]=",ExpressionUUID->"0086edb1-8e29-4c73-8dea-99d5acffc0e2"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"cond", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"ew", "->", "0.1"}], ",", 
     RowBox[{"ep", "->", "1"}], ",", 
     RowBox[{"v", "->", "0.5"}], ",", 
     RowBox[{"a", "->", "0.005"}], ",", 
     RowBox[{"e", "->", "10"}]}], "}"}]}], "\n"}]], "Input",
 CellChangeTimes->{{3.9768145988063183`*^9, 3.976814654209126*^9}, {
  3.976814731915427*^9, 3.976814752804985*^9}},
