  RowBox[{"ropt", "=", 
   RowBox[{
    FractionBox[
     RowBox[{
      RowBox[{"-", "ep"}], "+", 
      SqrtBox[
       RowBox[{
        RowBox[{"2", " ", 
         SuperscriptBox["e", "2"], " ", "\[Alpha]", " ", "v"}], "+", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"ep", "-", "ew"}], ")"}], "2"]}]], "+", "ew"}], 
     RowBox[{"e", " ", "\[Alpha]"}]], "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"ew", "->", "0.1"}], ",", 
      RowBox[{"ep", "->", "1"}], ",", 
      RowBox[{"v", "->", "0.5"}], ",", 
      RowBox[{"e", "->", "10"}]}], "}"}]}]}], "\n"}]], "Input",
